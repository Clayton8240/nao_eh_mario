{
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.git": true,
        "**/.vs": true,
        "**/.gitmodules": true,
        "**/.vsconfig": true,
        "**/*.booproj": true,
        "**/*.pidb": true,
        "**/*.suo": true,
        "**/*.user": true,
        "**/*.userprefs": true,
        "**/*.unityproj": true,
        "Assets/**/*.dll": true,
        "Assets/**/*.exe": true,
        "**/*.pdf": true,
        "**/*.mid": true,
        "**/*.midi": true,
        "**/*.wav": true,
        "Assets/**/*.gif": true,
        "Assets/**/*.ico": true,
        "Assets/**/*.jpg": true,
        "Assets/**/*.jpeg": true,
        "Assets/**/*.png": true,
        "Assets/**/*.psd": true,
        "Assets/**/*.tga": true,
        "Assets/**/*.tif": true,
        "Assets/**/*.tiff": true,
        "Assets/**/*.3ds": true,
        "Assets/**/*.3DS": true,
        "Assets/**/*.fbx": true,
        "Assets/**/*.FBX": true,
        "Assets/**/*.lxo": true,
        "Assets/**/*.LXO": true,
        "Assets/**/*.ma": true,
        "Assets/**/*.MA": true,
        "Assets/**/*.obj": true,
        "Assets/**/*.OBJ": true,
        "Assets/**/*.asset": true,
        "Assets/**/*.cubemap": true,
        "Assets/**/*.flare": true,
        "Assets/**/*.mat": true,
        "Assets/**/*.meta": true,
        "Assets/**/*.prefab": true,
        "Assets/**/*.unity": true,
        // "build/": true,
        // "Build/": true,
        "Library/": true,
        "library/": true,
        "obj/": true,
        "Obj/": true,
        "Logs/": true,
        "logs/": true,
        "ProjectSettings/": true,
        "UserSettings/": true,
        "temp/": true,
        "Temp/": true
    },
    "files.associations": {
        "*.asset": "yaml",
        "*.meta": "yaml",
        "*.prefab": "yaml",
        "*.unity": "yaml",
    },
    "yaml.validate": false,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.sln": "*.csproj",
        "*.slnx": "*.csproj"
    },
    "dotnet.defaultSolution": "não é mario.slnx",
    "dotnet.enableWorkspaceBasedDevelopment": false
}